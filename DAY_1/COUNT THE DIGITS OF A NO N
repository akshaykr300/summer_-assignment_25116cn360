#include <stdio.h>

int main() {
    int n;
    int count = 0;
    
    printf("Enter an integer: ");
    scanf("%d", &n);
    printf("The number n =%d\n",n);

    
    if (n == 0) {
        count = 1;
    } else {            //if no n is positive
    
        while (n != 0) {
            n /= 10;     
            count++;   
        }
    }

    printf("Number of digits: %d", count);
    return 0;
}
