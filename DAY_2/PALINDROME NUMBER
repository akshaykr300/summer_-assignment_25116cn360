#include <stdio.h>

int main() {
    int n, original, rev = 0, dig;

    printf("Enter an integer: ");
    scanf("%d", &n);

    original = n; 

    // Reverse the number
    while (n != 0) {
        dig = n % 10;         
        rev = rev * 10 + dig; 
        n /= 10;                     
    }


    if (original == rev)
        printf("%d is a palindrome.\n", original);
    else
        printf("%d is not a palindrome.\n", original);

    return 0;
}
