#include <stdio.h>

int main() {
    int n, sum = 0, digit;
    printf("Enter a number: ");
    scanf("%d", &n);

    //THE NO N SHOULD BE POSITIVE
    while (n > 0) {
        digit = n % 10;   
        sum += digit;    
        n /= 10;          
    }

    printf("Sum of digits= %d\n", sum);
    return 0;
}
