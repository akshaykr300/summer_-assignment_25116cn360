#include <stdio.h>

int main() {
    int n, rev = 0, dig;

    printf("Enter an integer n for which you find reverse: ");
    scanf("%d", &n);
    
  //REVERSE OF THE NO N
    while (n != 0) {
        dig = n % 10;          
        rev = rev * 10 + dig; 
        n /= 10;               
    }

    printf("Reversed number = %d\n", rev);

    return 0;
}
