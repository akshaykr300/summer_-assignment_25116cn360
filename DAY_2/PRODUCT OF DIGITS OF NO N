#include <stdio.h>

int main() {
    int n, dig, prod = 1;

    printf("Enter a number n to find product of digit: ");
    scanf("%d", &n);

    
    if (n == 0)
     prod = 0;

    while (n != 0) {
        dig = n % 10;     
        prod *= dig;     
        n /= 10;         
    }

    printf("Product of digits: %d\n", prod);
    return 0;
}
