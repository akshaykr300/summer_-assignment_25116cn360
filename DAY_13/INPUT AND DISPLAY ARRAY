#include <stdio.h>

int main () {
     
    int i,n,a[100];

    printf("enter the array size : ");
    scanf("%d",&n);

    printf("enter the element of array : \n");
    for(i=0;i<n;i++){
        scanf("%d",&a[i]);

    }
    printf("Array elements are:\n");

    for(i = 0; i < n; i++)
    {
        printf("%d ", a[i]);
    }
    return 0;
}
