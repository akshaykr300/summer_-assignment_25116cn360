#include <stdio.h>

int main () {
     
    int i,n,a[100],key,found=0;

    printf("enter the array size : ");
    scanf("%d",&n);

    printf("enter the element of array : \n");
    for(i=0;i<n;i++){
        scanf("%d",&a[i]);

    }
    printf("Enter element to search: ");
    scanf("%d", &key);

    for(i = 0; i < n; i++)
    {
        if(a[i] == key)
        {
            found = 1;
            printf("Element found at position %d", i + 1);
            break;
        }
    }

    if(found == 0)
    {
        printf("Element not found");
    }

    return 0;
}
