#include <stdio.h>

// Function declaration
int maximum(int a, int b);

int main() {
    int x, y, max;

    printf("Enter number x : ");
    scanf("%d", &x);

    printf("Enter number Y : ");
    scanf("%d", &y);

    max = maximum(x, y);

    printf("Maximum number = %d", max);

    return 0;
}

// Function definition
int maximum(int a, int b) {
    if(a > b)
        return a;
    else
        return b;
}
