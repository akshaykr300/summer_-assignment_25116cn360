#include <stdio.h>

struct Employee {
    int id;
    char name[50];
    char department[50];
    float basic, hra, da, pf, netSalary;
};

int main() {
    struct Employee emp[100];
    int n = 0;
    int choice, id, i, j, found;

    do {
        printf("\n========== EMPLOYEE MANAGEMENT SYSTEM ==========\n");
        printf("1. Add Employee\n");
        printf("2. Display All Employees\n");
        printf("3. Search Employee\n");
        printf("4. Update Employee\n");
        printf("5. Delete Employee\n");
        printf("6. Display Net Salary\n");
        printf("7. Exit\n");

        printf("Enter Your Choice: ");
        scanf("%d", &choice);

        switch(choice) {

        case 1:
            printf("\nEnter Employee ID: ");
            scanf("%d", &emp[n].id);

            printf("Enter Employee Name: ");
            scanf(" %[^\n]", emp[n].name);

            printf("Enter Department: ");
            scanf(" %[^\n]", emp[n].department);

            printf("Enter Basic Salary: ");
            scanf("%f", &emp[n].basic);

            emp[n].hra = emp[n].basic * 0.20;
            emp[n].da  = emp[n].basic * 0.10;
            emp[n].pf  = emp[n].basic * 0.05;

            emp[n].netSalary = emp[n].basic + emp[n].hra + emp[n].da - emp[n].pf;

            n++;
            printf("Employee Added Successfully!\n");
            break;

        case 2:
            if(n == 0) {
                printf("No Employee Records Found!\n");
                break;
            }

            printf("\n-------------------------------------------------------------------------------\n");
            printf("ID\tName\t\tDepartment\tBasic\tNet Salary\n");
            printf("-------------------------------------------------------------------------------\n");

            for(i = 0; i < n; i++) {
                printf("%d\t%-15s%-15s%.2f\t%.2f\n",
                       emp[i].id,
                       emp[i].name,
                       emp[i].department,
                       emp[i].basic,
                       emp[i].netSalary);
            }
            break;

        case 3:
            printf("Enter Employee ID to Search: ");
            scanf("%d", &id);

            found = 0;

            for(i = 0; i < n; i++) {
                if(emp[i].id == id) {
                    printf("\nEmployee Found\n");
                    printf("ID         : %d\n", emp[i].id);
                    printf("Name       : %s\n", emp[i].name);
                    printf("Department : %s\n", emp[i].department);
                    printf("Basic      : %.2f\n", emp[i].basic);
                    printf("HRA        : %.2f\n", emp[i].hra);
                    printf("DA         : %.2f\n", emp[i].da);
                    printf("PF         : %.2f\n", emp[i].pf);
                    printf("Net Salary : %.2f\n", emp[i].netSalary);

                    found = 1;
                    break;
                }
            }

            if(found == 0)
                printf("Employee Not Found!\n");
            break;

        case 4:
            printf("Enter Employee ID to Update: ");
            scanf("%d", &id);

            found = 0;

            for(i = 0; i < n; i++) {
                if(emp[i].id == id) {

                    printf("Enter New Name: ");
                    scanf(" %[^\n]", emp[i].name);

                    printf("Enter New Department: ");
                    scanf(" %[^\n]", emp[i].department);

                    printf("Enter New Basic Salary: ");
                    scanf("%f", &emp[i].basic);

                    emp[i].hra = emp[i].basic * 0.20;
                    emp[i].da  = emp[i].basic * 0.10;
                    emp[i].pf  = emp[i].basic * 0.05;

                    emp[i].netSalary = emp[i].basic + emp[i].hra + emp[i].da - emp[i].pf;

                    printf("Employee Updated Successfully!\n");
                    found = 1;
                    break;
                }
            }

            if(found == 0)
                printf("Employee Not Found!\n");
            break;

        case 5:
            printf("Enter Employee ID to Delete: ");
            scanf("%d", &id);

            found = 0;

            for(i = 0; i < n; i++) {
                if(emp[i].id == id) {

                    for(j = i; j < n - 1; j++) {
                        emp[j] = emp[j + 1];
                    }

                    n--;
                    printf("Employee Deleted Successfully!\n");
                    found = 1;
                    break;
                }
            }

            if(found == 0)
                printf("Employee Not Found!\n");
            break;

        case 6:
            if(n == 0) {
                printf("No Employee Records Found!\n");
                break;
            }

            printf("\n---------------- Employee Salary Details ----------------\n");
            printf("ID\tName\t\tNet Salary\n");
            printf("---------------------------------------------------------\n");

            for(i = 0; i < n; i++) {
                printf("%d\t%-15s%.2f\n",
                       emp[i].id,
                       emp[i].name,
                       emp[i].netSalary);
            }
            break;

        case 7:
            printf("Thank You!\n");
            break;

        default:
            printf("Invalid Choice!\n");
        }

    } while(choice != 7);

    return 0;
}
