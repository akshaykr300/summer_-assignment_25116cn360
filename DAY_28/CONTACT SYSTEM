#include <stdio.h>

struct Contact {
    int id;
    char name[50];
    char phone[15];
    char email[50];
};

int main() {
    struct Contact c[5];
    int i;

    // Input Contact Details
    for(i = 0; i < 5; i++) {
        printf("\nEnter Details of Contact %d\n", i + 1);

        printf("Enter Contact ID: ");
        scanf("%d", &c[i].id);

        printf("Enter Name: ");
        scanf("%s", c[i].name);

        printf("Enter Phone Number: ");
        scanf("%s", c[i].phone);

        printf("Enter Email ID: ");
        scanf("%s", c[i].email);
    }

    // Display Contact Details
    printf("\n================ CONTACT MANAGEMENT SYSTEM ================\n");
    printf("ID\tName\t\tPhone Number\t\tEmail\n");

    for(i = 0; i < 5; i++) {
        printf("%d\t%s\t\t%s\t\t%s\n",
               c[i].id,
               c[i].name,
               c[i].phone,
               c[i].email);
    }

    return 0;
}
