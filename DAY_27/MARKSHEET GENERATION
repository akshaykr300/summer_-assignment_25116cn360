#include <stdio.h>

int main() {
    int roll;
    char name[50];
    float m1, m2, m3, m4, m5;
    float total, percentage;

    printf("========== MARKSHEET GENERATION ==========\n");

    printf("Enter Roll Number: ");
    scanf("%d", &roll);

    printf("Enter Student Name: ");
    scanf("%s", name);

    printf("Enter Marks of 5 Subjects:\n");
    printf("Subject 1: ");
    scanf("%f", &m1);

    printf("Subject 2: ");
    scanf("%f", &m2);

    printf("Subject 3: ");
    scanf("%f", &m3);

    printf("Subject 4: ");
    scanf("%f", &m4);

    printf("Subject 5: ");
    scanf("%f", &m5);

    total = m1 + m2 + m3 + m4 + m5;
    percentage = total / 5;

    printf("\n=====================================\n");
    printf("          STUDENT MARKSHEET\n");
    printf("=====================================\n");
    printf("Roll Number : %d\n", roll);
    printf("Name        : %s\n", name);

    printf("\n-------------------------------------\n");
    printf("Subject\t\tMarks\n");
    printf("-------------------------------------\n");
    printf("Subject 1\t%.2f\n", m1);
    printf("Subject 2\t%.2f\n", m2);
    printf("Subject 3\t%.2f\n", m3);
    printf("Subject 4\t%.2f\n", m4);
    printf("Subject 5\t%.2f\n", m5);
    printf("-------------------------------------\n");
    printf("Total\t\t%.2f\n", total);
    printf("Percentage\t%.2f%%\n", percentage);

    if (percentage >= 90)
        printf("Grade\t\tA+\n");
    else if (percentage >= 80)
        printf("Grade\t\tA\n");
    else if (percentage >= 70)
        printf("Grade\t\tB\n");
    else if (percentage >= 60)
        printf("Grade\t\tC\n");
    else if (percentage >= 50)
        printf("Grade\t\tD\n");
    else
        printf("Grade\t\tF\n");

    printf("=====================================\n");

    return 0;
}
