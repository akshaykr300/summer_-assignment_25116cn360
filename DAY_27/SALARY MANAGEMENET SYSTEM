#include <stdio.h>

struct Employee {
    int id;
    char name[50];
    float basic, hra, da, pf, gross, net;
};

int main() {
    struct Employee e[5];
    int i;

    // Input Employee Details
    for(i = 0; i < 5; i++) {
        printf("\nEnter Details of Employee %d\n", i + 1);

        printf("Enter Employee ID: ");
        scanf("%d", &e[i].id);

        printf("Enter Employee Name: ");
        scanf("%s", e[i].name);

        printf("Enter Basic Salary: ");
        scanf("%f", &e[i].basic);

        // Salary Calculation
        e[i].hra = e[i].basic * 0.20;   // 20% HRA
        e[i].da = e[i].basic * 0.10;    // 10% DA
        e[i].pf = e[i].basic * 0.05;    // 5% PF

        e[i].gross = e[i].basic + e[i].hra + e[i].da;
        e[i].net = e[i].gross - e[i].pf;
    }

    // Display Salary Details
    printf("\n================ SALARY MANAGEMENT SYSTEM ================\n");
    printf("ID\tName\tBasic\tHRA\tDA\tPF\tGross\tNet\n");

    for(i = 0; i < 5; i++) {
        printf("%d\t%s\t%.2f\t%.2f\t%.2f\t%.2f\t%.2f\t%.2f\n",
               e[i].id,
               e[i].name,
               e[i].basic,
               e[i].hra,
               e[i].da,
               e[i].pf,
               e[i].gross,
               e[i].net);
    }

    return 0;
}
