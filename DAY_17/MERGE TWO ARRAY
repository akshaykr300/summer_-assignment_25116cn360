#include <stdio.h>

int main() {
    int n, m, i;

    printf("Enter size of first array: ");
    scanf("%d", &n);

    int a[n];

    printf("Enter elements of first array: ");
    for(i = 0; i < n; i++) {
        scanf("%d", &a[i]);
    }

    printf("Enter size of second array: ");
    scanf("%d", &m);

    int b[m];

    printf("Enter elements of second array: ");
    for(i = 0; i < m; i++) {
        scanf("%d", &b[i]);
    }

    int merge[n + m];

    for(i = 0; i < n; i++) {
        merge[i] = a[i];
    }

    for(i = 0; i < m; i++) {
        merge[n + i] = b[i];
    }

    printf("Merged Array:\n");
    for(i = 0; i < n + m; i++) {
        printf("%d ", merge[i]);
    }

    return 0;
}
