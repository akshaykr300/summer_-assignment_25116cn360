#include <stdio.h>

int main() {
    int n, m, i, j, found;

    printf("Enter size of first array: ");
    scanf("%d", &n);

    int a[n];

    printf("Enter elements of first array: ");
    for(i = 0; i < n; i++) {
        scanf("%d", &a[i]);
    }

    printf("Enter size of second array: ");
    scanf("%d", &m);

    int b[m];

    printf("Enter elements of second array: ");
    for(i = 0; i < m; i++) {
        scanf("%d", &b[i]);
    }

    int unionArr[n + m];
    int k = 0;

    // Copy first array
    for(i = 0; i < n; i++) {
        unionArr[k++] = a[i];
    }

    // Add unique elements from second array
    for(i = 0; i < m; i++) {
        found = 0;

        for(j = 0; j < k; j++) {
            if(b[i] == unionArr[j]) {
                found = 1;
                break;
            }
        }

        if(found == 0) {
            unionArr[k++] = b[i];
        }
    }

    printf("Union of arrays:\n");
    for(i = 0; i < k; i++) {
        printf("%d ", unionArr[i]);
    }

    return 0;
}
