#include <stdio.h>

struct Product {
    int id;
    char name[50];
    float price;
    int quantity;
};

int main() {
    struct Product p[100];
    int n = 0;
    int choice, i, id, found;
    float totalValue;

    do {
        printf("\n========== INVENTORY MANAGEMENT SYSTEM ==========\n");
        printf("1. Add Product\n");
        printf("2. Display All Products\n");
        printf("3. Search Product by ID\n");
        printf("4. Update Product Quantity\n");
        printf("5. Delete Product\n");
        printf("6. Total Inventory Value\n");
        printf("7. Exit\n");
        printf("Enter your choice: ");
        scanf("%d", &choice);

        switch(choice) {

        case 1:
            printf("Enter Product ID: ");
            scanf("%d", &p[n].id);

            printf("Enter Product Name: ");
            scanf("%s", p[n].name);

            printf("Enter Product Price: ");
            scanf("%f", &p[n].price);

            printf("Enter Product Quantity: ");
            scanf("%d", &p[n].quantity);

            n++;
            printf("Product Added Successfully!\n");
            break;

        case 2:
            if(n == 0) {
                printf("No Products Available!\n");
                break;
            }

            printf("\nID\tName\tPrice\tQuantity\n");
            printf("-----------------------------------------\n");

            for(i = 0; i < n; i++) {
                printf("%d\t%s\t%.2f\t%d\n",
                       p[i].id,
                       p[i].name,
                       p[i].price,
                       p[i].quantity);
            }
            break;

        case 3:
            printf("Enter Product ID to Search: ");
            scanf("%d", &id);

            found = 0;

            for(i = 0; i < n; i++) {
                if(p[i].id == id) {
                    printf("\nProduct Found\n");
                    printf("ID       : %d\n", p[i].id);
                    printf("Name     : %s\n", p[i].name);
                    printf("Price    : %.2f\n", p[i].price);
                    printf("Quantity : %d\n", p[i].quantity);
                    found = 1;
                    break;
                }
            }

            if(found == 0)
                printf("Product Not Found!\n");
            break;

        case 4:
            printf("Enter Product ID: ");
            scanf("%d", &id);

            found = 0;

            for(i = 0; i < n; i++) {
                if(p[i].id == id) {
                    printf("Current Quantity: %d\n", p[i].quantity);
                    printf("Enter New Quantity: ");
                    scanf("%d", &p[i].quantity);

                    printf("Quantity Updated Successfully!\n");
                    found = 1;
                    break;
                }
            }

            if(found == 0)
                printf("Product Not Found!\n");
            break;

        case 5:
            printf("Enter Product ID to Delete: ");
            scanf("%d", &id);

            found = 0;

            for(i = 0; i < n; i++) {
                if(p[i].id == id) {
                    int j;
                    for(j = i; j < n - 1; j++) {
                        p[j] = p[j + 1];
                    }
                    n--;
                    printf("Product Deleted Successfully!\n");
                    found = 1;
                    break;
                }
            }

            if(found == 0)
                printf("Product Not Found!\n");
            break;

        case 6:
            totalValue = 0;

            for(i = 0; i < n; i++) {
                totalValue += p[i].price * p[i].quantity;
            }

            printf("Total Inventory Value = %.2f\n", totalValue);
            break;

        case 7:
            printf("Thank You!\n");
            break;

        default:
            printf("Invalid Choice!\n");
        }

    } while(choice != 7);

    return 0;
}
