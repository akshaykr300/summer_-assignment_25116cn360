#include <stdio.h>
#include <math.h>

int main() {
    int n, temp, rem, dig = 0;
    int result = 0;

    printf("Enter a number to check: ");
    scanf("%d", &n);

    temp = n;

    /* Count digits */
    while (temp != 0) {
        dig++;
        temp /= 10;
    }

    temp = n;

    /* Calculate sum of digits raised to power of digits */
    while (temp != 0) {
        rem = temp % 10;
        result += pow(rem, dig);
        temp /= 10;
    }

    if (result == n)
        printf("%d is an Armstrong number.\n", n);
    else
        printf("%d is not an Armstrong number.\n", n);

    return 0;
}
