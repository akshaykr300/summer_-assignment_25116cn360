#include <stdio.h>
#include <math.h>

int main() {
    int startno, endno, n, temp, rem, dig;
    int sum;

    printf("Enter starting number: ");
    scanf("%d", &startno);

    printf("Enter ending number: ");
    scanf("%d", &endno);

    printf("Armstrong numbers between %d and %d are:\n", startno, endno);

    for (n = startno; n <= endno; n++) {
        temp = n;
        dig = 0;
        sum = 0;

        while (temp != 0) {
            dig++;
            temp /= 10;
        }

        temp = n;

        while (temp != 0) {
            rem = temp % 10;
            sum += pow(rem, dig);
            temp /= 10;
        }

        if (sum == n)
            printf("%d ", n);
    }

    return 0;
}
