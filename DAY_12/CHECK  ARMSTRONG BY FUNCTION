#include <stdio.h>

int armstrong(int n)
{
    int original = n, temp, rem;
    int digits = 0, sum = 0;

    // Count digits
    temp = n;
    while (temp > 0)
    {
        digits++;
        temp = temp / 10;
    }

    temp = n;

    // Calculate Armstrong sum
    while (temp > 0)
    {
        rem = temp % 10;

        int power = 1;
        for (int i = 1; i <= digits; i++)
        {
            power = power * rem;
        }

        sum = sum + power;
        temp = temp / 10;
    }

    return (sum == original);
}

int main()
{
    int n;

    printf("Enter a number: ");
    scanf("%d", &n);

    if (armstrong(n))
        printf("%d is an Armstrong Number", n);
    else
        printf("%d is not an Armstrong Number", n);

    return 0;
}
